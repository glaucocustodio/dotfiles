[alias]
  st = status
  ps = push
  pl = pull
  d  = diff
  rs = restore --staged
  cm = commit -m
  cma = commit --amend -m
  dc = diff --cached
  rh = reset HEAD
  b  = branch
  cp = cherry-pick
  sh = show HEAD
  sho = show
  force = push --force-with-lease
  # checkout branch with fzf
  #
  # usage:
  #
  # $ git co <branch> (switch to branch immediately)
  # $ git co (use fzf to select branch, previewing last 20 commits and opening last commit details with ctrl+o)
  #
  co = "!f() { \
    if [ -n \"$1\" ]; then \
      git checkout \"$@\"; \
    else \
      branch=$(git for-each-ref --sort=-committerdate --format='%(refname:short)' refs/heads refs/remotes | grep -v HEAD | \
        fzf --ansi \
            --preview 'git log --oneline --graph --decorate --color=always {} | head -20' \
            --preview-window=right:60% \
            --bind \"ctrl-o:execute(git show --color=always {} | less -R)+ignore\" \
      ); \
      [ -n \"$branch\" ] && git checkout \"$branch\"; \
    fi; \
  }; f"
[color]
  ui = true
[user]
  name = Glauco Custodio
  email = glauco.custodio@gmail.com
[pull]
  rebase = true # avoid: git pull --rebase, just: git pull
[branch]
  # recent commited first
  sort = -committerdate
[core]
  editor = /usr/bin/vim
  # https://tekin.co.uk/2020/10/better-git-diff-output-for-ruby-python-elixir-and-more
  attributesFile = ~/.gitattributes
  # improve mouse scroll on git diff
	pager = less -+$LESS -R --chop-long-lines
# not in use
# [color "diff-highlight"]
#   oldNormal="red bold"
#   # number after bold is color, check: https://en.wikipedia.org/wiki/ANSI_escape_code#8-bit
#   oldHighlight="red bold 52"
#   newNormal="green bold 70"
#   newHighlight="green bold 40"
